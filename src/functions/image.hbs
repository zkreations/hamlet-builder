{{!--
Create an image tag with optional attributes and responsive support
@author zkreations
@param {image} src - Image URL
@param {number[]} [sourceSet] - Array of image widths (e.g. [320, 640, 1024])
@param {string} [width] - Image width
@param {string} [height] - Image height
@param {number} [resize] - Change dimensions
@param {string} [ratio] - Aspect ratio
@param {string} [id] - Image ID
@param {string} [class] - Additional classes
@param {string} [sizes] - Sizes attribute
@param {string} [loading] - Loading attribute
@param {string} [fetchpriority] - Fetch priority attribute
@param {string} [crossorigin] - Cross-origin attribute
@param {string} [decoding] - Decoding attribute
@param {string} [referrerpolicy] - Referrer policy attribute
@param {string} [alt] - Alt text
@param {string} [params] - Additional parameters for proxy images
--}}
<b:includable id='@image'>
  <b:if cond='data:src'>
    <b:with value='data:src.isYoutube
      ? data:src.youtubeMaxResDefaultUrl
      : data:src' var='baseImage'>
      <b:with value='(data:resize
        ? resizeImage(data:baseImage, data:resize, data:ratio)
        : (data:baseImage)
      )' var='image'>
        <b:tag name='img'>
          <b:attr name='b:whitespace' value='remove'/>
          <b:class cond='data:class' expr:name='data:class'/>
          {{!-- Add data attributes for each of the specified attributes if they exist --}}
          <b:loop values='["id","sizes","loading","fetchpriority","crossorigin","decoding","referrerpolicy","alt"]' var='attr'>
            <b:with expr:value='+("data:",data:attr)' var='value'>
              <b:attr expr:name='data:attr' expr:value='data:value'/>
            </b:with>
          </b:loop>
          {{!-- Check if the image is from a proxy server and append parameters if necessary --}}
          <b:with value='[
            "com/img/a/",
            "com/blogger_img_proxy"
          ] any (server => server in data:image)' var='isProxyImg'>
            <b:with value='data:params and data:isProxyImg ? ("-" + data:params) : ""' var='params'>
              <b:with value='data:sourceSet ? resizeImage(data:image, data:sourceSet.first, data:ratio) : data:image' var='image'>
                <b:attr name='src' expr:value='data:src + data:params'/>
                <b:attr name='width' expr:value='data:width ?: data:image.width'/>
                <b:attr name='height' expr:value='data:height ?: data:image.height'/>
              </b:with>
            </b:with>
          </b:with>
          {{!-- If sourceSet is provided, generate the srcset attribute --}}
          <b:if cond='data:sourceSet'>
            <b:attr name='srcset' expr:value='sourceSet(data:image, data:sourceSet, data:ratio)'/>
          </b:if>
        </b:tag>
      </b:with>
    </b:with>
  <b:else/>
    <b:comment render='true'>Parameter [src] is required.</b:comment>
  </b:if>
</b:includable>
